<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DeskQuit.ViewModels"
        x:Class="DeskQuit.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/deskquit16.ico"
        Title="DeskQuit"
        Width="600" Height="750"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Custom Title Bar -->
        <Border Height="40" Background="Transparent" VerticalAlignment="Top">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Text="DeskQuit" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Foreground="White" FontSize="16"/>
                <!-- This empty border is for dragging the window -->
                <Border Background="Transparent" Grid.Column="0" PointerPressed="OnTitleBarPointerPressed"/>
            </Grid>
        </Border>

        <Grid Margin="0,40,0,0" RowDefinitions="*">
            
            <TabControl Grid.Row="0" Background="#111827">
                <TabItem Header="{Binding RemindersTabHeader}">
                    <Grid RowDefinitions="Auto, *">
                        <TextBox Grid.Row="0" Text="{Binding SearchQuery}" Watermark="{Binding SearchWatermarkText}" Margin="10,10,10,0" />
                        
                        <ScrollViewer Grid.Row="1">
                            <StackPanel Margin="10">
                                <ItemsControl ItemsSource="{Binding FilteredReminders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ReminderSettingViewModel">
                                            <Border Background="#1F2937" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*,Auto">
                                                    
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Button Content="Удалить" Command="{Binding DeleteCommand}" IsVisible="{Binding IsCustom}" Background="#EF4444" Foreground="White" Padding="8,4" CornerRadius="4"/>
                                                        <Button Content="Редактировать" Command="{Binding EditCommand}" IsVisible="{Binding IsCustom}" IsEnabled="{Binding IsNotEditing}" Background="#3B82F6" Foreground="White" Padding="8,4" CornerRadius="4"/>
                                                        <Button Content="Сохранить" Command="{Binding SaveCommand}" IsVisible="{Binding IsEditing}" Background="#10B981" Foreground="White" Padding="8,4" CornerRadius="4"/>
                                                        <ToggleSwitch IsChecked="{Binding IsEnabled}" Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                    
                                                    <Panel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                                        <TextBox Text="{Binding Title}" Watermark="{Binding TitleWatermark}" FontWeight="Bold" FontSize="18" Foreground="White" IsVisible="{Binding IsEditing}"/>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center" IsVisible="{Binding IsNotEditing}" TextWrapping="Wrap"/>
                                                    </Panel>
                                                    
                                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Description}" Watermark="{Binding DescriptionWatermark}" TextWrapping="Wrap" FontSize="14" Foreground="#D1D5DB" Margin="0,10,0,0" IsVisible="{Binding IsEditing}" MinHeight="60" AcceptsReturn="True"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Description}" TextWrapping="Wrap" FontSize="14" Foreground="#D1D5DB" Margin="0,10,0,0" IsVisible="{Binding IsNotEditing}"/>
                                                    
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Source}" TextWrapping="Wrap" FontSize="12" Foreground="#9CA3AF" FontStyle="Italic" Margin="0,10,0,0" IsVisible="{Binding !IsCustom}"/>

                                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Spacing="15" Margin="0,15,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                            <TextBlock Text="Интервал (мин):" VerticalAlignment="Center" Foreground="White" Width="130"/>
                                                            <NumericUpDown Value="{Binding IntervalInMinutes}" Minimum="1" Maximum="180" Width="130" FormatString="0"/>
                                                            <TextBlock Text="Вы отклонились от реком. интервала" 
                                                                    Foreground="#F87171" 
                                                                    IsVisible="{Binding ShowIntervalWarning}"
                                                                    VerticalAlignment="Center"
                                                                    TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        
                                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                            <TextBlock Text="Стиль уведомления:" VerticalAlignment="Center" Foreground="White" Width="130"/>
                                                            <ComboBox ItemsSource="{Binding AvailableStyles}" 
                                                                      SelectedItem="{Binding SelectedStyleOption}" 
                                                                      DisplayMemberBinding="{Binding DisplayName}"
                                                                      Width="250"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Button Content="{Binding AddCustomReminderButtonText}" 
                                        Command="{Binding AddCustomReminderCommand}" 
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,20"
                                        Padding="20,10"
                                        CornerRadius="8"
                                        Background="#10B981"
                                        Foreground="White"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                
                <TabItem Header="{Binding TimerTabHeader}">
                    <ScrollViewer>
                        <StackPanel Margin="10" Spacing="15">
                            <Border Background="#1F2937" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="15">
                                    <TextBlock Text="{Binding TimerTabHeader}" FontWeight="Bold" FontSize="18" Foreground="White"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TimerWidthLabel}" VerticalAlignment="Center" Foreground="White" Width="130"/>
                                        <NumericUpDown Value="{Binding TimerWidth}" Minimum="100" Maximum="500" Width="130" FormatString="0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TimerHeightLabel}" VerticalAlignment="Center" Foreground="White" Width="130"/>
                                        <NumericUpDown Value="{Binding TimerHeight}" Minimum="40" Maximum="200" Width="130" FormatString="0"/>
                                    </StackPanel>

                                    <Button Content="{Binding ToggleTimerButtonText}" 
                                            Command="{Binding ToggleFloatingTimerCommand}" 
                                            HorizontalAlignment="Left"
                                            Padding="15,8"
                                            CornerRadius="8"
                                            Background="#2563EB"
                                            Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding SettingsTabHeader}">
                    <ScrollViewer>
                        <StackPanel Margin="10" Spacing="15">
                            <Border Background="#1F2937" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Глобальные настройки" FontWeight="Bold" FontSize="18" Foreground="White"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0" VerticalAlignment="Center">
                                        <ToggleSwitch IsChecked="{Binding RunOnStartup}"/>
                                        <TextBlock Text="{Binding RunOnStartupLabel}" VerticalAlignment="Center" Foreground="White"/>
                                    </StackPanel>

                                    <TextBlock Text="DeskQuit останавливает таймеры, если вы отходите от компьютера." TextWrapping="Wrap" FontSize="14" Foreground="#D1D5DB" Margin="0,15,0,0"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AfkThresholdLabel}" VerticalAlignment="Center" Foreground="White"/>
                                        <NumericUpDown Value="{Binding AfkThresholdMinutes}" Minimum="1" Maximum="60" Width="130" FormatString="0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Добавлено поле для базового адреса API -->
                            <Border Background="#1F2937" CornerRadius="8" Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Синхронизация" FontWeight="Bold" FontSize="18" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ServerUrlLabel}" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBox Text="{Binding ServerUrl}" Width="250"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding AccountTabHeader}">
                    <ScrollViewer>
                        <Border Background="#1F2937" CornerRadius="8" Padding="15" Margin="10">
                            <Grid>
                                <!-- Стейт: не авторизован -->
                                <StackPanel IsVisible="{Binding !AccountViewModel.IsAuthenticated}" Spacing="15" MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AccountViewModel.AccountHeader}" FontWeight="Bold" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AccountViewModel.NotLoggedInText}" TextWrapping="Wrap" FontSize="14" Foreground="#D1D5DB" TextAlignment="Center" Margin="0,0,0,15"/>
                                    
                                    <TextBox Text="{Binding AccountViewModel.EmailInput}" Watermark="{Binding AccountViewModel.EmailWatermark}" MinHeight="40"/>
                                    <TextBox Text="{Binding AccountViewModel.PasswordInput}" Watermark="{Binding AccountViewModel.PasswordWatermark}" PasswordChar="*" MinHeight="40"/>
                                    
                                    <TextBlock Text="{Binding AccountViewModel.ErrorMessage}" Foreground="#EF4444" IsVisible="{Binding AccountViewModel.ErrorMessage.Length, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,10,0,0">
                                        <Button Content="{Binding AccountViewModel.LoginButtonText}" Command="{Binding AccountViewModel.LoginCommand}" Background="#3B82F6" Foreground="White" Padding="20,10" CornerRadius="8" IsEnabled="{Binding !AccountViewModel.IsLoading}"/>
                                        <Button Content="{Binding AccountViewModel.RegisterButtonText}" Command="{Binding AccountViewModel.RegisterCommand}" Background="#10B981" Foreground="White" Padding="20,10" CornerRadius="8" IsEnabled="{Binding !AccountViewModel.IsLoading}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Стейт: авторизован -->
                                <StackPanel IsVisible="{Binding AccountViewModel.IsAuthenticated}" Spacing="20">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="👤" FontSize="24" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding AccountViewModel.CurrentUserEmail}" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{Binding AccountViewModel.LogoutButtonText}" Command="{Binding AccountViewModel.LogoutCommand}" Background="#EF4444" Foreground="White" Padding="15,8" CornerRadius="8"/>
                                    </Grid>

                                    <Border Background="#374151" CornerRadius="8" Padding="15">
                                        <StackPanel Spacing="15">
                                            <TextBlock Text="{Binding AccountViewModel.StatsHeader}" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,0,0,5"/>
                                            
                                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" Margin="0,5">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AccountViewModel.ActiveTimeText}" Foreground="#D1D5DB" FontSize="15" Margin="0,0,0,10"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AccountViewModel.CurrentSessionActiveTime}" FontWeight="SemiBold" Foreground="White" FontSize="15" Margin="0,0,0,10"/>
                                                
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AccountViewModel.AfkTimeText}" Foreground="#D1D5DB" FontSize="15" Margin="0,0,0,10"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AccountViewModel.CurrentSessionAfkTime}" FontWeight="SemiBold" Foreground="White" FontSize="15" Margin="0,0,0,10"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding AccountViewModel.NotifsFiredText}" Foreground="#D1D5DB" FontSize="15"/>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding AccountViewModel.CurrentSessionNotificationsFiredTotal}" FontWeight="SemiBold" Foreground="White" FontSize="15"/>
                                                    <TextBlock Text=" (" Foreground="#D1D5DB" FontSize="15"/>
                                                    <TextBlock Text="{Binding AccountViewModel.CurrentSessionNotificationsFiredCustom}" FontWeight="SemiBold" Foreground="White" FontSize="15"/>
                                                    <TextBlock Text=" custom)" Foreground="#D1D5DB" FontSize="15"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </TabItem>
                
                <TabItem Header="{Binding InfoTabHeader}">
                    <ScrollViewer>
                        <Border Background="#1F2937" CornerRadius="8" Padding="15" Margin="10">
                            <TextBlock Text="{Binding InfoContent}" TextWrapping="Wrap" FontSize="14" Foreground="#D1D5DB" LineHeight="22"/>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Panel>
</Window>